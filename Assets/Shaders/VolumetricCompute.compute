            // The ray is inside the box the whole time that it's inside the sphere, which is the same thing as only using the spherical bounding box.
            if (boxIntersect.x < sphere2intersect.x && boxIntersect.y > sphere2intersect.y) combine_bounds = false;
            
            // The player is inside both spheres and the ray is inside the box while inbetween the spheres.
