                            }
                        }
                    }
                }
                
                float stepSize = distance(sphere2entry, sphere1entry) / _StepAmount;
                float4 res = raymarch(sphere2entry, sphere1entry,entryPos, _FogColor.rgb,stepSize / (float)2,_StepAmount / (float)2,viewLength,1.0,id.xy);
                stepSize = distance(sphere2exit, sphere1exit) / _StepAmount;
