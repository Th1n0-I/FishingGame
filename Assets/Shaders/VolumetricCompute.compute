    }*/
    
    if (_UseBoundingBox)
    {
        float2 entryExit = get_box_bounds(entryPos, rayDir);
        
        // The ray doesn't intersect with the bounding box. Return immediately.
        if (entryExit.y < 0.0 || entryExit.x >= entryExit.y) return;
        
        float3 intersectPoint = entryPos + rayDir * entryExit.x;
        float3 exitPoint = entryPos + rayDir * entryExit.y;
        
        // The player is inside the box, use the camera's position as the start point and the exit as the end point.
        if (entryExit.x < 0.0 && entryExit.y > 0.0)
        {
            float stepSize = distance(entryPos, exitPoint) / _StepAmount;
            float4 res = raymarch(entryPos, exitPoint,entryPos, _FogColor.rgb,stepSize,_StepAmount,viewLength,1.0,id.xy);
            Result[id.xy] = float4(res.rgb, 1.0 - saturate(res.a));
            return;
        }
        
        // The player is outside the box and the ray intersects with it
        if (entryExit.x > 0.0 && entryExit.x < entryExit.y)
        {
            float stepSize = distance(intersectPoint, exitPoint) / _StepAmount;
            float4 res = raymarch(intersectPoint, exitPoint,entryPos, _FogColor.rgb,stepSize,_StepAmount,viewLength,1.0,id.xy);
            Result[id.xy] = float4(res.rgb, 1.0 - saturate(res.a));
            return;
        }
    }
